{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "python3 -m pip install --disable-pip-version-check -r requirements.txt && cd dashboard && npm ci",
  "buildCommand": "bash scripts/vercel-build.sh",
  "builds": [{ "src": "app.py", "use": "@vercel/python" }],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "app.py" }
  ]
}
